# VCS
.git/
.gitignore
.gitattributes

# Build outputs
build/
build-*/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json

# IDE / local tools
.vs/
.vscode/
.idea/
.tmp-jluna/

# Clangd / LSP caches
.cache/

# jluna .src symlink (local build artifact)
.src

# Binary artifacts
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dll
*.dylib
*.exe
*.out
*.pdb

# OS junk
.DS_Store
Thumbs.db

# Large data files not needed in Docker build
tle2025.txt
data.txt
ps.txt

# Julia build artifacts
build_julia/

# Frontend node_modules excluded (npm ci runs inside Docker)
frontend/node_modules/
frontend/dist/

# Documentation (except groundstations.csv, copied explicitly)
*.md
LICENSE

# Docker files themselves (avoid recursive context)
Dockerfile
.dockerignore
docker-compose*.yml

# Editor backup files
*~
*.swp
*.swo